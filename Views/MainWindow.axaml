<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:D4Pressure.ViewModels"
        xmlns:conv="using:Avalonia.Data.Converters"
        x:Class="D4Pressure.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="D4Pressure"
        Width="960" Height="660"
        MinWidth="860" MinHeight="520"
        Background="#0a0a18"
        Topmost="True"
        FontFamily="Inter, Segoe UI, sans-serif"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>

    <!-- Pulse animation -->
    <Style Selector="Rectangle.pulse, Ellipse.pulse">
      <Style.Animations>
        <Animation Duration="0:0:1.5" IterationCount="Infinite">
          <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.2"/></KeyFrame>
          <KeyFrame Cue="50%"> <Setter Property="Opacity" Value="1.0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.2"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Toggle button pulsing when running -->
    <Style Selector="Button.toggle-running">
      <Style.Animations>
        <Animation Duration="0:0:1.2" IterationCount="Infinite">
          <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.8"/></KeyFrame>
          <KeyFrame Cue="50%"> <Setter Property="Opacity" Value="1.0"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.8"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Base button -->
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.85"/>
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <!-- TextBox -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#0d0d22"/>
      <Setter Property="BorderBrush" Value="#2a2a50"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#d0d0e8"/>
      <Setter Property="CaretBrush" Value="#ff6600"/>
      <Setter Property="SelectionBrush" Value="#7c3aed"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="6,0"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="#ff6600"/>
    </Style>

    <!-- ComboBox -->
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#0d0d22"/>
      <Setter Property="Foreground" Value="#d0d0e8"/>
      <Setter Property="BorderBrush" Value="#2a2a50"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="6,0"/>
    </Style>
    <Style Selector="ComboBox /template/ Border#Background">
      <Setter Property="Background" Value="#0d0d22"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="ComboBoxItem">
      <Setter Property="Background" Value="#0f0f22"/>
      <Setter Property="Foreground" Value="#d0d0e8"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1a1a38"/>
    </Style>

    <!-- NumericUpDown -->
    <Style Selector="NumericUpDown">
      <Setter Property="Background" Value="#0d0d22"/>
      <Setter Property="Foreground" Value="#ff6600"/>
      <Setter Property="BorderBrush" Value="#2a2a50"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="NumericUpDown /template/ TextBox">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#ff6600"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8,0"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- ToggleSwitch -->
    <Style Selector="ToggleSwitch">
      <Setter Property="OnContent" Value=""/>
      <Setter Property="OffContent" Value=""/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- Key capture button -->
    <Style Selector="Button.key-btn">
      <Setter Property="Background" Value="#1a1a38"/>
      <Setter Property="Foreground" Value="#aaaacc"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="4,0"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#2a2a50"/>
    </Style>
    <Style Selector="Button.key-btn.capturing">
      <Setter Property="Background" Value="#7c3aed"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#a855f7"/>
    </Style>
    <Style Selector="Button.key-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#252550"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- Remove button hover -->
    <Style Selector="Button.remove-btn:pointerover /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="#ef4444"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

  </Window.Styles>

  <!-- Root -->
  <Grid ColumnDefinitions="0.72*,0.28*">

      <!-- ══════════════════════ LEFT PANEL ══════════════════════ -->
      <DockPanel Grid.Column="0" Background="#0a0a18">

        <!-- Column header -->
        <Border DockPanel.Dock="Top" Background="#0a0a18" Padding="8,7">
          <Grid ColumnDefinitions="8,52,*,90,200,56,34">
            <TextBlock Grid.Column="2" Text="KEY"
                       Foreground="#ff6600" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="MODE"
                       Foreground="#ff6600" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="MS  (±20%)"
                       Foreground="#ff6600" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="ACTIVE"
                       Foreground="#ff6600" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <Rectangle DockPanel.Dock="Top" Height="1" Fill="#ff6600" Opacity="0.25"/>

        <!-- Add Row button -->
        <Button DockPanel.Dock="Bottom"
                Command="{Binding AddRowCommand}"
                Content="＋  Add Row"
                Background="#cc5200"
                Foreground="White"
                FontWeight="SemiBold"
                FontSize="13"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Height="38"
                CornerRadius="0"
                Padding="0">
          <Button.Styles>
            <Style Selector="Button:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="#ff6600"/>
              <Setter Property="Opacity" Value="1"/>
            </Style>
          </Button.Styles>
        </Button>

        <!-- Row list -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Rows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:KeyRowViewModel">

                <Border Margin="4,2"
                        CornerRadius="6"
                        Background="#13132a"
                        BorderBrush="#222240"
                        BorderThickness="1">
                  <Grid ColumnDefinitions="8,52,*,90,200,56,34"
                        MinHeight="54"
                        VerticalAlignment="Stretch">

                    <!-- Active pulse indicator -->
                    <Rectangle Grid.Column="0"
                               Width="4"
                               Fill="#22c55e"
                               RadiusX="3" RadiusY="3"
                               VerticalAlignment="Stretch"
                               Classes.pulse="{Binding IsActive}"
                               Opacity="0.2"/>

                    <!-- Icon area -->
                    <Button Grid.Column="1"
                            Command="{Binding StartCaptureCommand}"
                            Width="44" Height="44"
                            CornerRadius="6"
                            Background="#080816"
                            BorderBrush="#2a2a50"
                            BorderThickness="1"
                            Margin="4"
                            Cursor="Hand"
                            Padding="0"
                            VerticalAlignment="Center">
                      <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                          <Setter Property="Background" Value="#0d0d1e"/>
                          <Setter Property="Opacity" Value="1"/>
                        </Style>
                      </Button.Styles>
                      <Panel>
                        <Image Source="{Binding Icon}"
                               Stretch="UniformToFill"
                               IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <TextBlock Text="?"
                                   Foreground="#3a3a6a"
                                   FontSize="24" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNull}}"/>
                      </Panel>
                    </Button>

                    <!-- Key capture button -->
                    <Button Grid.Column="2"
                            Classes="key-btn"
                            Classes.capturing="{Binding IsCapturing}"
                            Command="{Binding StartCaptureCommand}"
                            Content="{Binding KeyDisplayName}"
                            Height="36"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            FontSize="14"
                            Margin="2,0"/>

                    <!-- Mode -->
                    <ComboBox Grid.Column="3"
                              SelectedItem="{Binding Mode}"
                              ItemsSource="{x:Static vm:MainViewModel.KeyModes}"
                              Height="36"
                              FontSize="13"
                              HorizontalAlignment="Stretch"
                              Margin="2,0"/>

                    <!-- Delay ms -->
                    <NumericUpDown Grid.Column="4"
                                   Value="{Binding DelayMs}"
                                   Minimum="10"
                                   Maximum="99999"
                                   Increment="100"
                                   ShowButtonSpinner="False"
                                   Height="36"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FormatString="0"
                                   HorizontalAlignment="Stretch"
                                   Margin="4,0,8,0"/>

                    <!-- Active toggle -->
                    <ToggleSwitch Grid.Column="5"
                                  IsChecked="{Binding IsEnabled}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                    <!-- Remove -->
                    <Button Grid.Column="6"
                            Classes="remove-btn"
                            Command="{Binding RemoveCommand}"
                            Content="×"
                            Background="Transparent"
                            Foreground="#555555"
                            FontSize="18" FontWeight="Bold"
                            Width="28" Height="28"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            CornerRadius="4"
                            VerticalAlignment="Center"/>

                  </Grid>
                </Border>

              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

      </DockPanel>

      <!-- ══════════════════════ RIGHT PANEL ══════════════════════ -->
      <DockPanel Grid.Column="1" Background="#0f0f22">

        <Rectangle DockPanel.Dock="Left" Width="1" Fill="#1a1a38"/>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="18,18,18,18" Spacing="0">

            <!-- Title -->
            <TextBlock Text="D4Pressure"
                       FontSize="26" FontWeight="Black"
                       Foreground="#ff6600"/>
            <TextBlock Text="Skill Rotator"
                       FontSize="11" Foreground="#555555"
                       Margin="2,2,0,0"/>

            <Rectangle Height="1" Fill="#1a1a38" Margin="0,14,0,0"/>

            <!-- Toggle button -->
            <Button Content="{Binding ToggleLabel}"
                    Command="{Binding ToggleCommand}"
                    Background="{Binding ToggleColor}"
                    Foreground="White"
                    FontSize="15" FontWeight="Bold"
                    Height="48"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    CornerRadius="6"
                    Margin="0,14,0,0"/>

            <!-- Scan Icons -->
            <Button Content="📷  Scan Icons"
                    Command="{Binding ScanScreenCommand}"
                    Background="#1a0a3a"
                    Foreground="#a855f7"
                    FontSize="12" FontWeight="SemiBold"
                    Height="38"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    CornerRadius="6"
                    Margin="0,8,0,0"
                    BorderBrush="#3d1a7a"
                    BorderThickness="1"/>

            <TextBlock Text="{Binding ScanStatus}"
                       Foreground="#888888"
                       FontSize="11"
                       Margin="0,4,0,0"
                       IsVisible="{Binding ScanStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Character selector -->
            <Border Background="#0a0a18"
                    CornerRadius="6"
                    Padding="10,10"
                    Margin="0,8,0,0">
              <StackPanel Spacing="8">

                <TextBlock Text="CHARACTER"
                           Foreground="#444444"
                           FontSize="9" FontWeight="Bold"
                           LetterSpacing="2"/>

                <Grid ColumnDefinitions="*,4,32"
                      IsVisible="{Binding !IsAddingCharacter}">
                  <ComboBox Grid.Column="0"
                            ItemsSource="{Binding Characters}"
                            SelectedItem="{Binding SelectedCharacter}"
                            Height="34"
                            HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:CharacterProfile">
                        <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Button Grid.Column="2"
                          Command="{Binding DeleteCharacterCommand}"
                          Content="×"
                          Background="Transparent"
                          Foreground="#555555"
                          FontSize="18" FontWeight="Bold"
                          Width="32" Height="34"
                          Padding="0"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center"
                          CornerRadius="4">
                    <Button.Styles>
                      <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="TextElement.Foreground" Value="#ef4444"/>
                        <Setter Property="Opacity" Value="1"/>
                      </Style>
                    </Button.Styles>
                  </Button>
                </Grid>

                <Button Content="＋  New Character"
                        Command="{Binding AddCharacterCommand}"
                        IsVisible="{Binding !IsAddingCharacter}"
                        Background="#0d1a0d"
                        Foreground="#16a34a"
                        FontSize="12" FontWeight="SemiBold"
                        Height="30"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        CornerRadius="4"
                        BorderBrush="#1a3a1a"
                        BorderThickness="1"/>

                <StackPanel IsVisible="{Binding IsAddingCharacter}" Spacing="6">
                  <TextBlock Text="Name" Foreground="#555555" FontSize="10"/>
                  <TextBox Text="{Binding NewCharacterName}"
                           Watermark="Character name…"
                           Height="32"/>
                  <TextBlock Text="Class" Foreground="#555555" FontSize="10" Margin="0,2,0,0"/>
                  <ComboBox ItemsSource="{x:Static vm:MainViewModel.D4Classes}"
                            SelectedItem="{Binding NewCharacterClass}"
                            Height="32"
                            HorizontalAlignment="Stretch"/>
                  <Grid ColumnDefinitions="*,6,*" Margin="0,2,0,0">
                    <Button Grid.Column="0"
                            Command="{Binding ConfirmAddCharacterCommand}"
                            Content="Add"
                            Background="#16a34a" Foreground="White"
                            FontSize="12" FontWeight="SemiBold"
                            Height="30"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            CornerRadius="4"/>
                    <Button Grid.Column="2"
                            Command="{Binding CancelAddCharacterCommand}"
                            Content="Cancel"
                            Background="#1a1a38" Foreground="#888888"
                            FontSize="12"
                            Height="30"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            CornerRadius="4"/>
                  </Grid>
                </StackPanel>

              </StackPanel>
            </Border>

            <Rectangle Height="1" Fill="#1a1a38" Margin="0,14,0,0"/>

            <!-- Status indicator -->
            <StackPanel Orientation="Horizontal" Spacing="8"
                        Margin="0,12,0,0" VerticalAlignment="Center">
              <Ellipse Width="10" Height="10"
                       Fill="{Binding StatusColor}"
                       Classes.pulse="{Binding IsRunning}"
                       VerticalAlignment="Center"/>
              <TextBlock Text="{Binding StatusText}"
                         Foreground="{Binding StatusColor}"
                         FontSize="12" FontWeight="Bold"
                         LetterSpacing="2"
                         VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Hotkeys card -->
            <Border Background="#0a0a18"
                    CornerRadius="6"
                    Padding="10,8"
                    Margin="0,12,0,0">
              <StackPanel Spacing="5">
                <TextBlock Text="HOTKEYS"
                           Foreground="#444444"
                           FontSize="9" FontWeight="Bold"
                           LetterSpacing="2"/>
                <!-- F2 -->
                <Grid ColumnDefinitions="Auto,*">
                  <Border Background="#1a1a38" CornerRadius="3" Padding="5,2" Margin="0,0,8,0">
                    <TextBlock Text="F2" Foreground="#7c3aed"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="11" FontWeight="Bold"/>
                  </Border>
                  <TextBlock Grid.Column="1" Text="Toggle start/stop"
                             Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
                <!-- F3 -->
                <Grid ColumnDefinitions="Auto,*">
                  <Border Background="#1a1a38" CornerRadius="3" Padding="5,2" Margin="0,0,8,0">
                    <TextBlock Text="F3" Foreground="#7c3aed"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="11" FontWeight="Bold"/>
                  </Border>
                  <TextBlock Grid.Column="1" Text="Toggle overlay mode"
                             Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
                <!-- F9 -->
                <Grid ColumnDefinitions="Auto,*">
                  <Border Background="#1a1a38" CornerRadius="3" Padding="5,2" Margin="0,0,8,0">
                    <TextBlock Text="F9" Foreground="#7c3aed"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="11" FontWeight="Bold"/>
                  </Border>
                  <TextBlock Grid.Column="1" Text="Quit app"
                             Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                </Grid>

                <!-- Extra toggle key binding -->
                <Rectangle Height="1" Fill="#1a1a38" Margin="0,4,0,0"/>
                <TextBlock Text="EXTRA TOGGLE KEY"
                           Foreground="#444444" FontSize="9" FontWeight="Bold"
                           LetterSpacing="2" Margin="0,2,0,0"/>
                <Button Classes="key-btn"
                        Classes.capturing="{Binding IsCapturingToggleKey}"
                        Command="{Binding StartToggleKeyCaptureCommand}"
                        Content="{Binding ToggleKeyDisplay}"
                        Height="30"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
              </StackPanel>
            </Border>

            <Rectangle Height="1" Fill="#1a1a38" Margin="0,14,0,0"/>

            <!-- Window opacity -->
            <StackPanel Margin="0,10,0,0" Spacing="4">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Overlay opacity"
                           Foreground="#555555" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding WindowOpacity, StringFormat={}{0:P0}}"
                           Foreground="#555555" FontSize="11"
                           VerticalAlignment="Center"/>
              </Grid>
              <Slider Value="{Binding WindowOpacity}"
                      Minimum="0.3" Maximum="1.0"
                      TickFrequency="0.05" SmallChange="0.05"
                      Foreground="#ff6600"/>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>

      </DockPanel>

      <!-- ══════════ KEY CAPTURE OVERLAY (spans full window) ══════════ -->
      <Border Grid.Column="0" Grid.ColumnSpan="2"
              ZIndex="100"
              IsVisible="{Binding IsCapturing}"
              Background="#dd050510"
              Focusable="True"
              x:Name="CaptureOverlay"
              KeyDown="CaptureOverlay_KeyDown"
              PointerPressed="CaptureOverlay_PointerPressed">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#0f0f22"
                CornerRadius="10"
                Padding="48,32"
                BorderBrush="#7c3aed"
                BorderThickness="1">
          <StackPanel Spacing="12" HorizontalAlignment="Center">
            <TextBlock Text="BIND INPUT"
                       Foreground="#7c3aed"
                       FontSize="11" FontWeight="Bold"
                       LetterSpacing="3"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Press a key or click a mouse button"
                       Foreground="#ff6600"
                       FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Esc to cancel"
                       Foreground="#444444"
                       FontSize="11"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Border>

    </Grid>

</Window>
