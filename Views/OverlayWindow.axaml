<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:D4Pressure.ViewModels"
        x:Class="D4Pressure.Views.OverlayWindow"
        x:DataType="vm:MainViewModel"
        Title="D4Pressure Overlay"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Width="200" Height="52"
        MinWidth="120" MinHeight="40"
        CanResize="True"
        Topmost="True"
        WindowStartupLocation="Manual"
        Opacity="{Binding WindowOpacity}">

  <Window.Styles>

    <!-- Key shape — base -->
    <Style Selector="Border.kbd-key">
      <Setter Property="Width"        Value="15"/>
      <Setter Property="Height"       Value="13"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Background"   Value="#ff6600"/>
      <Setter Property="Margin"       Value="2,0"/>
      <Setter Property="Opacity"      Value="0.3"/>
    </Style>

    <!-- Staggered brightness wave (k1–k6) -->
    <Style Selector="Border.kbd-key.k1">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.00" IterationCount="Infinite"
                   PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.3"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.kbd-key.k2">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.075" IterationCount="Infinite"
                   PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.3"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.kbd-key.k3">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.15" IterationCount="Infinite"
                   PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.3"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.kbd-key.k4">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.225" IterationCount="Infinite"
                   PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.3"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.kbd-key.k5">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.30" IterationCount="Infinite"
                   PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.3"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.kbd-key.k6">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.375" IterationCount="Infinite"
                   PlaybackDirection="Alternate" Easing="SineEaseInOut">
          <KeyFrame Cue="0%">  <Setter Property="Opacity" Value="0.3"/></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Button resets -->
    <Style Selector="Button">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Transitions">
        <Transitions><DoubleTransition Property="Opacity" Duration="0:0:0.1"/></Transitions>
      </Setter>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.85"/>
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.7"/>
    </Style>

  </Window.Styles>

  <!--
    Layout:
      Resize handles (transparent strips, ZIndex=10) overlay the content.
      Content border fills the window (minus 4px margin for resize strip visibility).
      Move drag is triggered by pressing anywhere on the content border except the button.
  -->
  <Grid>

    <!-- ── Content ────────────────────────────────────────────── -->
    <Border x:Name="ContentBorder"
            Background="#e8090918"
            CornerRadius="8"
            BorderBrush="#2a2a52"
            BorderThickness="1"
            Margin="4"
            PointerPressed="Content_PointerPressed">

      <Grid Margin="8">

        <!-- Toggle button — custom content based on running state -->
        <Button Command="{Binding ToggleCommand}"
                Background="{Binding ToggleColor}"
                Foreground="White"
                FontFamily="Inter, Segoe UI, sans-serif"
                FontWeight="Bold"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                VerticalAlignment="Stretch"
                CornerRadius="5"
                Padding="4,0">

          <Panel>

            <!-- START state -->
            <TextBlock Text="▶  START  (F2)"
                       FontSize="14"
                       IsVisible="{Binding !IsRunning}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- RUNNING state — bouncing keys + STOP label -->
            <StackPanel IsVisible="{Binding IsRunning}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="3">
              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Center">
                <Border Classes="kbd-key k1"/>
                <Border Classes="kbd-key k2"/>
                <Border Classes="kbd-key k3"/>
                <Border Classes="kbd-key k4"/>
                <Border Classes="kbd-key k5"/>
                <Border Classes="kbd-key k6"/>
              </StackPanel>
              <TextBlock Text="■  STOP"
                         FontSize="11"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"/>
            </StackPanel>

          </Panel>
        </Button>

      </Grid>
    </Border>

    <!-- ── Resize handles ─────────────────────────────────────── -->

    <!-- Edges -->
    <Border Height="5" VerticalAlignment="Top"    Background="Transparent" Cursor="SizeNorthSouth"  ZIndex="10" PointerPressed="Resize_N"/>
    <Border Height="5" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNorthSouth"  ZIndex="10" PointerPressed="Resize_S"/>
    <Border Width="5"  HorizontalAlignment="Left"  Background="Transparent" Cursor="SizeWestEast"   ZIndex="10" PointerPressed="Resize_W"/>
    <Border Width="5"  HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWestEast"   ZIndex="10" PointerPressed="Resize_E"/>

    <!-- Corners -->
    <Border Width="12" Height="12" HorizontalAlignment="Left"  VerticalAlignment="Top"    Background="Transparent" Cursor="TopLeftCorner"     ZIndex="11" PointerPressed="Resize_NW"/>
    <Border Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top"    Background="Transparent" Cursor="TopRightCorner"    ZIndex="11" PointerPressed="Resize_NE"/>
    <Border Width="12" Height="12" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomLeftCorner"  ZIndex="11" PointerPressed="Resize_SW"/>
    <Border Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="BottomRightCorner" ZIndex="11" PointerPressed="Resize_SE"/>

  </Grid>

</Window>
